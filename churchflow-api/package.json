    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "prisma": "5.19.1",
    "ts-node-dev": "2.0.0",
    "tslib": "2.6.3",
    "typescript": "5.5.4",
    "tsx": "4.16.2",
    "@types/bcryptjs": "2.4.2",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.6",
    "@types/morgan": "1.9.9"
